# ChatSaaS Backend Environment Configuration
# Copy this file to .env and update with your actual values

# Application
DEBUG=true
APP_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/chatsaas

# JWT Authentication (generate secure keys in production)
JWT_SECRET_KEY=your-secret-key-minimum-32-characters-long-for-security
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# AI Provider Selection
AI_PROVIDER=google
EMBEDDING_PROVIDER=google

# Google AI
GOOGLE_API_KEY=your-google-api-key

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Groq
GROQ_API_KEY=your-groq-api-key

# Channel Secrets
TELEGRAM_SECRET_TOKEN=your-telegram-secret
WHATSAPP_APP_SECRET=your-whatsapp-app-secret
INSTAGRAM_APP_SECRET=your-instagram-app-secret

# Email Service (Resend)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=alerts@yourdomain.com
RESEND_WEBHOOK_SECRET=your-resend-webhook-secret

# SMTP (Brevo / SMTP relay)
# Example (Brevo): smtp-relay.brevo.com on port 587
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Brevo webhook secret (if using Brevo webhooks)
BREVO_WEBHOOK_SECRET=

# File Storage
STORAGE_PATH=/var/chatsaas/storage

# Security (generate secure keys in production)
ENCRYPTION_KEY=your-32-byte-hex-key-64-characters-long-for-aes256-encryption
PROCESS_SECRET=your-process-secret-minimum-32-characters-long

# Administration
SUPER_ADMIN_EMAIL=admin@yourdomain.com