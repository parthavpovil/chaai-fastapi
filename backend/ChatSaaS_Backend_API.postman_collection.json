    {
      "name": "Conversations",
      "description": "Manage customer conversations, escalations, and agent assignments.",
      "item": [
        {
          "name": "GET List Conversations",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/conversations/?status_filter=active&assigned_to_me=false&limit=50&offset=0",
              "host": ["{{base_url}}"],
              "path": ["api", "conversations", ""],
              "query": [
                { "key": "status_filter", "value": "active", "description": "Filter by status: active, escalated, agent, resolved. Optional." },
                { "key": "assigned_to_me", "value": "false", "description": "Only show conversations assigned to current agent (bool, default false)." },
                { "key": "limit", "value": "50", "description": "Max results (1-100, default 50)." },
                { "key": "offset", "value": "0", "description": "Pagination offset (default 0)." }
              ]
            },
            "description": "List conversations with optional filters."
          },
          "response": []
        },
        {
          "name": "GET Conversation Detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/conversations/{{conversation_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "conversations", "{{conversation_id}}"]
            },
            "description": "Get full conversation detail including all messages."
          },
          "response": []
        },
        {
          "name": "POST Claim Conversation",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/conversations/claim",
              "host": ["{{base_url}}"],
              "path": ["api", "conversations", "claim"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"conversation_id\": \"{{conversation_id}}\"\n}"
            },
            "description": "Agent claims an escalated conversation."
          },
          "response": []
        },
        {
          "name": "POST Update Conversation Status",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/conversations/status",
              "host": ["{{base_url}}"],
              "path": ["api", "conversations", "status"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"conversation_id\": \"{{conversation_id}}\",\n  \"status\": \"resolved\",\n  \"note\": \"Issue resolved by agent\"\n}"
            },
            "description": "Update conversation status. Possible statuses: active, escalated, agent, resolved."
          },
          "response": []
        },
        {
          "name": "POST Send Agent Message",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/conversations/{{conversation_id}}/messages",
              "host": ["{{base_url}}"],
              "path": ["api", "conversations", "{{conversation_id}}", "messages"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"content\": \"Hello! I'm here to help you. Could you please describe your issue in more detail?\"\n}"
            },
            "description": "Agent sends a message in a conversation (max 2000 chars)."
          },
          "response": []
        },
        {
          "name": "GET Conversation Stats",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/conversations/stats/summary",
              "host": ["{{base_url}}"],
              "path": ["api", "conversations", "stats", "summary"]
            },
            "description": "Get conversation statistics for the workspace."
          },
          "response": []
        },
        {
          "name": "GET My Active Conversations",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/conversations/my/active?limit=50&offset=0",
              "host": ["{{base_url}}"],
              "path": ["api", "conversations", "my", "active"],
              "query": [
                { "key": "limit", "value": "50", "description": "Max results (1-100, default 50)." },
                { "key": "offset", "value": "0", "description": "Pagination offset." }
              ]
            },
            "description": "Get conversations assigned to the current agent."
          },
          "response": []
        }
      ]
    },
    {
