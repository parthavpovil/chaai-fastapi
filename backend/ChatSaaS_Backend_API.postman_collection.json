              "raw": "{\n  \"channel_type\": \"telegram\",\n  \"name\": \"My Telegram Bot\",\n  \"is_active\": true,\n  \"credentials\": {\n    \"bot_token\": \"123456789:AABBCCDDEEFFaabbccddeeff-1234567890\"\n  }\n}"
