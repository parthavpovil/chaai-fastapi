            "description": "Accept an agent invitation using the token from the email."
          },
          "response": []
        },
        {
          "name": "GET List Agents",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/agents/?include_inactive=false",
