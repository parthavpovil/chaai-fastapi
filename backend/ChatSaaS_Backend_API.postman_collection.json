{
  "info": {
    "_postman_id": "chatsaas-backend-api-v1",
    "name": "ChatSaaS Backend API",
    "description": "# ChatSaaS Backend API\n\nComplete API collection for the ChatSaaS Backend platform.\n\n## Environment Variables\n- `base_url`: API base URL (e.g. `http://localhost:8000`)\n- `access_token`: JWT token (auto-populated by login/register)\n- `workspace_id`: Current workspace ID (auto-populated)\n- `workspace_slug`: Current workspace slug (auto-populated)\n- `channel_id`: Channel ID (auto-populated)\n- `document_id`: Document ID (auto-populated)\n- `agent_id`: Agent ID (auto-populated)\n- `conversation_id`: Conversation ID (auto-populated)\n- `session_token`: WebChat session token (auto-populated)\n- `widget_id`: WebChat widget ID (auto-populated)\n- `invitation_token`: Agent invitation token (auto-populated)\n\n## Authentication\nMost endpoints require `Authorization: Bearer {{access_token}}`.\n\n## Trailing Slashes\nFastAPI routes are defined with trailing slashes. Always use `/api/channels/` not `/api/channels`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "2.0.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Authentication",
      "description": "User/agent registration, login, and token management.",
      "item": [
        {
          "name": "POST Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"owner@example.com\",\n  \"password\": \"securepassword123\",\n  \"business_name\": \"My Business\"\n}"
            },
            "description": "Register a new user and create a workspace. Returns JWT access token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var j = pm.response.json();",
                  "  pm.environment.set('access_token', j.access_token);",
                  "  if (j.workspace) {",
                  "    pm.environment.set('workspace_id', j.workspace.id);",
                  "    pm.environment.set('workspace_slug', j.workspace.slug);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "POST Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"owner@example.com\",\n  \"password\": \"securepassword123\"\n}"
            },
            "description": "Login as a workspace owner. Returns JWT access token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var j = pm.response.json();",
                  "  pm.environment.set('access_token', j.access_token);",
                  "  if (j.workspace) {",
                  "    pm.environment.set('workspace_id', j.workspace.id);",
                  "    pm.environment.set('workspace_slug', j.workspace.slug);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "POST Agent Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/auth/agent-login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "agent-login"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"agent@example.com\",\n  \"password\": \"agentpassword123\"\n}"
            },
            "description": "Login as an agent. Returns JWT access token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.environment.set('access_token', pm.response.json().access_token);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "POST Accept Invite",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/auth/accept-invite",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "accept-invite"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"token\": \"{{invitation_token}}\",\n  \"password\": \"agentpassword123\"\n}"
            },
            "description": "Accept an agent invitation and set password."
          },
          "response": []
        },
        {
          "name": "GET Me",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Get current authenticated user and workspace info."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Channels",
      "description": "Manage communication channels (WebChat, Telegram, WhatsApp, Instagram). NOTE: list/create routes require trailing slash.",
      "item": [
        {
          "name": "POST Create Channel (WebChat)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/channels/",
              "host": ["{{base_url}}"],
              "path": ["api", "channels", ""]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"channel_type\": \"webchat\",\n  \"name\": \"My Website Chat\",\n  \"is_active\": true,\n  \"credentials\": {\n    \"primary_color\": \"#007bff\",\n    \"position\": \"bottom-right\",\n    \"welcome_message\": \"Hello! How can we help you today?\"\n  }\n}"
            },
            "description": "Create a new WebChat channel. Trailing slash is required."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  var j = pm.response.json();",
                  "  pm.environment.set('channel_id', j.id);",
                  "  if (j.widget_id) pm.environment.set('widget_id', j.widget_id);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
