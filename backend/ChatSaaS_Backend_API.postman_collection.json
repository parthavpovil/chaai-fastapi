            "url": {
              "raw": "{{base_url}}/api/agents/invite",
              "host": ["{{base_url}}"],
              "path": ["api", "agents", "invite"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"agent@example.com\",\n  \"name\": \"Support Agent Name\"\n}"
            },
            "description": "Invite a new agent to the workspace. Sends invitation email."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  var j = pm.response.json();",
                  "  pm.environment.set('agent_id', j.id);",
                  "  if (j.invitation_token) pm.environment.set('invitation_token', j.invitation_token);",
                  "}"
                ]
              }
            }
          ],
          "response": []
