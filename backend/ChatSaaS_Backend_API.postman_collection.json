    {
      "name": "WebChat (Public)",
      "description": "Public WebChat endpoints — no auth required. Used by the widget embedded on customer websites.",
      "item": [
        {
          "name": "GET WebChat Config",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/webchat/config/{{workspace_slug}}",
              "host": ["{{base_url}}"],
              "path": ["api", "webchat", "config", "{{workspace_slug}}"]
            },
            "description": "Get WebChat widget config for a workspace (public). Used by the embedded widget."
          },
          "response": []
        },
        {
          "name": "POST WebChat Send Message",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/webchat/send",
              "host": ["{{base_url}}"],
              "path": ["api", "webchat", "send"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"widget_id\": \"{{widget_id}}\",\n  \"session_token\": \"{{session_token}}\",\n  \"message\": \"Hello, I need help with my order.\",\n  \"contact_name\": \"John Doe\"\n}"
            },
            "description": "Send a message via WebChat widget. `session_token` is optional on first message (auto-created). `contact_name` is optional. Rate limit: 10 msg/min per session."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var j = pm.response.json();",
                  "  if (j.session_token) pm.environment.set('session_token', j.session_token);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "GET WebChat Messages",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/webchat/messages?widget_id={{widget_id}}&session_token={{session_token}}&limit=50&offset=0",
              "host": ["{{base_url}}"],
              "path": ["api", "webchat", "messages"],
              "query": [
                { "key": "widget_id", "value": "{{widget_id}}", "description": "Widget ID (required)." },
                { "key": "session_token", "value": "{{session_token}}", "description": "Session token (required)." },
                { "key": "limit", "value": "50", "description": "Max messages (1-100, default 50)." },
                { "key": "offset", "value": "0", "description": "Pagination offset." }
              ]
            },
            "description": "Get message history for a WebChat session. Rate limit: 30 req/min per session."
          },
          "response": []
        }
      ]
    },
