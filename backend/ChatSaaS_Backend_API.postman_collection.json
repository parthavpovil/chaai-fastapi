              "raw": "{{base_url}}/api/agents/accept",
              "host": ["{{base_url}}"],
              "path": ["api", "agents", "accept"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"invitation_token\": \"{{invitation_token}}\"\n}"
