              { "key": "svix-timestamp", "value": "1234567890", "description": "Svix timestamp (sent by Resend)." },
              { "key": "svix-signature", "value": "v1,xxxxxxxxxxxx", "description": "Svix signature for verification (sent by Resend)." }
            ],
            "url": {
              "raw": "{{base_url}}/webhooks/resend",
              "host": ["{{base_url}}"],
              "path": ["webhooks", "resend"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"type\": \"email.delivered\",\n  \"data\": {\n    \"email_id\": \"email_xxxxxxxxxxxx\",\n    \"from\": \"noreply@example.com\",\n    \"to\": [\"agent@example.com\"],\n    \"subject\": \"You have been invited\",\n    \"created_at\": \"2026-03-20T12:00:00.000Z\"\n  }\n}"
            },
