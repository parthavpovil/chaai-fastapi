        {
          "name": "GET Agent Stats",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/agents/stats",
              "host": ["{{base_url}}"],
              "path": ["api", "agents", "stats"]
            },
            "description": "Get agent statistics: total, active, inactive, pending invitations."
          },
          "response": []
